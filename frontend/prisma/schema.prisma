// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

///////////////////////
// ENUMS
///////////////////////

enum PlatformRole {
  SUPER_ADMIN
}

enum OrganizationRole {
  ADMIN
  MEMBER
}

enum BusinessRole {
  NSM
  DSM
  DELEGATE
  ASSISTANT
}

enum DoctorType {
  PUBLIC
  PRIVATE
  CHU
}

enum PromoItemType {
  SAMPLE
  EMG
  GADGET
}

///////////////////////
// USER
///////////////////////

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String
  name         String
  address      String?
  phone        String?
  profileImageUrl String?
  isActive     Boolean @default(true)

  platformRole PlatformRole?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships OrganizationUser[]
}

///////////////////////
// ORGANIZATION
///////////////////////

model Organization {
  id       String  @id @default(uuid())
  name     String
  isActive Boolean @default(true)
  logoUrl  String?
  primaryColor String?
  secondaryColor String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships        OrganizationUser[]
  teams              Team[]
  sectors            Sector[]
  doctors            Doctor[]
  visits             Visit[]
  promoItems         PromotionalItem[]
  visitDistributions VisitDistribution[]
  stockAllocations   StockAllocation[]
}

///////////////////////
// MEMBERSHIP
///////////////////////

model OrganizationUser {
  id             String @id @default(uuid())
  userId         String
  organizationId String

  organizationRole OrganizationRole @default(MEMBER)
  businessRole     BusinessRole?

  managerId    String?
  manager      OrganizationUser?  @relation("UserManager", fields: [managerId], references: [id])
  subordinates OrganizationUser[] @relation("UserManager")

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id])

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  managedTeams     Team[]            @relation("TeamManager")
  managedSectors   Sector[]          @relation("SectorManager")
  delegateVisits   Visit[]           @relation("VisitDelegate")
  stockAllocations StockAllocation[]

  @@unique([userId, organizationId])
}

///////////////////////
// TEAM (DSM -> Delegates)
///////////////////////

model Team {
  id             String @id @default(uuid())
  name           String
  organizationId String
  managerId      String // DSM

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id])
  manager      OrganizationUser   @relation("TeamManager", fields: [managerId], references: [id])
  members      OrganizationUser[]
}

///////////////////////
// SECTOR (DSM)
///////////////////////

model Sector {
  id             String @id @default(uuid())
  name           String
  organizationId String
  managerId      String // DSM

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id])
  manager      OrganizationUser @relation("SectorManager", fields: [managerId], references: [id])
  doctors      Doctor[]
}

///////////////////////
// DOCTOR
///////////////////////

model Doctor {
  id             String     @id @default(uuid())
  firstName      String
  lastName       String
  speciality     String?
  address        String?
  phone          String?
  type           DoctorType
  sectorId       String?
  organizationId String
  

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  sector       Sector?      @relation(fields: [sectorId], references: [id])
  visits       Visit[]
}

///////////////////////
// VISIT (Delegate Activity)
///////////////////////

model Visit {
  id             String   @id @default(uuid())
  organizationId String
  doctorId       String
  delegateId     String
  visitedAt      DateTime
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id])
  doctor       Doctor           @relation(fields: [doctorId], references: [id])
  delegate     OrganizationUser @relation("VisitDelegate", fields: [delegateId], references: [id])

  distributions VisitDistribution[]
}

///////////////////////
// PROMO ITEMS
///////////////////////

model PromotionalItem {
  id             String        @id @default(uuid())
  organizationId String
  name           String
  type           PromoItemType
  totalStock     Int           @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization  Organization        @relation(fields: [organizationId], references: [id])
  distributions VisitDistribution[]
  allocations   StockAllocation[]
}

///////////////////////
// VISIT DISTRIBUTION
///////////////////////

model VisitDistribution {
  id             String @id @default(uuid())
  organizationId String
  visitId        String
  itemId         String
  quantity       Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  visit        Visit           @relation(fields: [visitId], references: [id])
  item         PromotionalItem @relation(fields: [itemId], references: [id])

  @@unique([visitId, itemId])
}

///////////////////////
// STOCK ALLOCATION (Assistante)
///////////////////////

model StockAllocation {
  id             String @id @default(uuid())
  organizationId String
  itemId         String
  delegateId     String
  quantity       Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id])
  item         PromotionalItem  @relation(fields: [itemId], references: [id])
  delegate     OrganizationUser @relation(fields: [delegateId], references: [id])
}
